generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

// ─── Enums ──────────────────────────────────────────────────────────

enum Privacy {
  PRIVATE
  FRIENDS
  PUBLIC
}

enum ReservationStatus {
  ACTIVE
  CANCELLED
  FULFILLED
}

enum NotificationType {
  PRICE_DROP
  NEW_ITEM
  RESERVATION
}

enum SubscriptionStatus {
  PENDING
  APPROVED
}

enum FriendshipStatus {
  PENDING
  ACCEPTED
}

enum ItemStatus {
  ACTIVE
  COMPLETED
}

// ─── Models ─────────────────────────────────────────────────────────

model User {
  id           String   @id @default(uuid()) @db.Uuid
  email        String   @unique @db.VarChar(255)
  passwordHash String   @map("password_hash") @db.VarChar(255)
  displayName  String   @map("display_name") @db.VarChar(100)
  avatarUrl    String?  @map("avatar_url")
  language     String   @default("en") @db.VarChar(5)
  currency     String   @default("USD") @db.VarChar(3)
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @default(now()) @updatedAt @map("updated_at")

  resetToken        String?   @map("reset_token")
  resetTokenExpires DateTime? @map("reset_token_expires")

  wishlists     Wishlist[]
  subscriptions Subscription[]
  reservations  Reservation[]
  notifications Notification[]
  
  // Relationships for friendships
  sentFriendRequests     Friendship[] @relation("SentFriendRequests")
  receivedFriendRequests Friendship[] @relation("ReceivedFriendRequests")
  sentInvitations        Invitation[] @relation("SentInvitations")

  @@map("users")
}

model Friendship {
  id        String           @id @default(uuid()) @db.Uuid
  userId    String           @map("user_id") @db.Uuid
  friendId  String           @map("friend_id") @db.Uuid
  status    FriendshipStatus @default(PENDING)
  createdAt DateTime         @default(now()) @map("created_at")
  updatedAt DateTime         @default(now()) @updatedAt @map("updated_at")

  user   User @relation("SentFriendRequests", fields: [userId], references: [id], onDelete: Cascade)
  friend User @relation("ReceivedFriendRequests", fields: [friendId], references: [id], onDelete: Cascade)

  @@unique([userId, friendId])
  @@index([userId])
  @@index([friendId])
  @@map("friendships")
}

model Invitation {
  id        String   @id @default(uuid()) @db.Uuid
  inviterId String   @map("inviter_id") @db.Uuid
  email     String   @db.VarChar(255)
  token     String   @unique @db.VarChar(255)
  isUsed    Boolean  @default(false) @map("is_used")
  createdAt DateTime @default(now()) @map("created_at")
  expiresAt DateTime @map("expires_at")

  inviter User @relation("SentInvitations", fields: [inviterId], references: [id], onDelete: Cascade)

  @@index([inviterId])
  @@index([email])
  @@map("invitations")
}

model Wishlist {
  id          String   @id @default(uuid()) @db.Uuid
  userId      String   @map("user_id") @db.Uuid
  title       String   @db.VarChar(200)
  description String?
  type        String?  @db.VarChar(100)
  emoji       String   @default("🎁") @db.VarChar(10)
  privacy     Privacy  @default(PRIVATE)
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @default(now()) @updatedAt @map("updated_at")

  user          User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  items         Item[]
  subscriptions Subscription[]

  @@index([userId])
  @@map("wishlists")
}

model Item {
  id           String   @id @default(uuid()) @db.Uuid
  wishlistId   String   @map("wishlist_id") @db.Uuid
  title        String   @db.VarChar(500)
  description  String?
  status       ItemStatus @default(ACTIVE)
  url          String
  imageUrl     String?  @map("image_url")
  currentPrice Decimal? @map("current_price") @db.Decimal(10, 2)
  currency     String   @default("USD") @db.VarChar(3)
  trackPrice   Boolean  @default(false) @map("track_price")
  priority     Int      @default(0)
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @default(now()) @updatedAt @map("updated_at")

  wishlist     Wishlist       @relation(fields: [wishlistId], references: [id], onDelete: Cascade)
  reservation  Reservation?
  priceHistory PriceHistory[]

  @@index([wishlistId])
  @@map("items")
}

model Reservation {
  id          String            @id @default(uuid()) @db.Uuid
  itemId      String            @unique @map("item_id") @db.Uuid
  userId      String            @map("user_id") @db.Uuid
  isAnonymous Boolean           @default(false) @map("is_anonymous")
  status      ReservationStatus @default(ACTIVE)
  createdAt   DateTime          @default(now()) @map("created_at")
  updatedAt   DateTime          @default(now()) @updatedAt @map("updated_at")

  item Item @relation(fields: [itemId], references: [id], onDelete: Cascade)
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([itemId])
  @@index([userId])
  @@map("reservations")
}

model Subscription {
  id             String   @id @default(uuid()) @db.Uuid
  userId         String   @map("user_id") @db.Uuid
  wishlistId     String             @map("wishlist_id") @db.Uuid
  status         SubscriptionStatus @default(APPROVED)
  notifyNewItems Boolean            @default(true) @map("notify_new_items")
  createdAt      DateTime @default(now()) @map("created_at")

  user     User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  wishlist Wishlist @relation(fields: [wishlistId], references: [id], onDelete: Cascade)

  @@unique([userId, wishlistId])
  @@index([userId])
  @@index([wishlistId])
  @@map("subscriptions")
}

model PriceHistory {
  id        String   @id @default(uuid()) @db.Uuid
  itemId    String   @map("item_id") @db.Uuid
  price     Decimal  @db.Decimal(10, 2)
  currency  String   @db.VarChar(3)
  checkedAt DateTime @default(now()) @map("checked_at")

  item Item @relation(fields: [itemId], references: [id], onDelete: Cascade)

  @@index([itemId])
  @@map("price_history")
}

model Notification {
  id            String           @id @default(uuid()) @db.Uuid
  userId        String           @map("user_id") @db.Uuid
  type          NotificationType
  title         String           @db.VarChar(200)
  message       String
  relatedItemId String?          @map("related_item_id") @db.Uuid
  isRead        Boolean          @default(false) @map("is_read")
  createdAt     DateTime         @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("notifications")
}
