DATABASE_URL="postgresql://wishtracker:wishtracker@localhost:5432/wishtracker?schema=public"
JWT_SECRET="your-super-secret-jwt-key-change-in-production"
JWT_EXPIRES_IN="7d"
PORT=3010
NODE_ENV=development

# Web app URL (password reset + invitation links)
APP_URL=http://localhost:3011

# Comma-separated origins for production CORS
CORS_ORIGINS=http://localhost:3011,http://localhost:5173

# Email (optional — logs to console when SMTP_HOST is unset)
MAIL_FROM="WishTracker <noreply@example.com>"
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=

# Price tracking cron (disabled when PRICE_TRACKING_ENABLED=false)
PRICE_TRACKING_ENABLED=true
PRICE_TRACKING_CRON="0 */6 * * *"
